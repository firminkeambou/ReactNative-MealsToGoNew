{
  "expo": {
    "name": "Meals To Go New",
    "slug": "MealsToGoNew",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_transparent.png",
    "scheme": "mealstogonew",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo_transparent.png",
        "backgroundImage": "./assets/images/logo_transparent.png",
        "monochromeImage": "./assets/images/logo_transparent.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.freemanexpo.MealsToGoNew"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ba427842-cd51-4653-a49d-22accd8707d5"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ba427842-cd51-4653-a49d-22accd8707d5"
    }
  }
}
