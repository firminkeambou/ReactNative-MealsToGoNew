{
  "expo": {
    "name": "Meals To Go New (preview)",
    "slug": "MealsToGoNew",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "mealstogonew",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.freemanexpo.MealsToGoNew.ios",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/home_bg.jpg",
        "backgroundImage": "./assets/images/home_bg.jpg",
        "monochromeImage": "./assets/images/home_bg.jpg"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.freemanexpo.MealsToGoNew",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c311b65c-0ae3-4a06-9a27-fbd9f193b5ca"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c311b65c-0ae3-4a06-9a27-fbd9f193b5ca"
    },
    "owner": "freemanexpo"
  }
}
